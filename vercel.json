{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/tenders", "dest": "/tenders.html" },
    { "src": "/onboarding", "dest": "/onboarding.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}